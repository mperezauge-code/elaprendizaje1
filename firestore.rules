rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Leads collection - anyone can create, only authenticated admins can read/delete
    match /leads/{leadId} {
      // Anyone can submit a lead (the form needs this)
      allow create: if true;
      
      // Only authenticated users can read leads
      allow read: if request.auth != null;
      
      // No one can update or delete leads from the client
      allow update, delete: if false;
    }
    
    // Block all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
